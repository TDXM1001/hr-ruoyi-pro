**Step 3: 实现盘点结果回写、处置确认、统计汇总**

```java
public void submitResult(AssetInventoryResultBo bo, String operator) {
    AssetLedger asset = assetLedgerMapper.selectById(bo.getAssetId());
    if ("DAMAGED".equals(bo.getResultType()) || "MISSING".equals(bo.getResultType())) {
        assetLedgerMapper.updateStatus(bo.getAssetId(), AssetStatus.PENDING_DISPOSAL.name());
    } else {
        assetLedgerMapper.updateStatus(bo.getAssetId(), bo.getConfirmedUse() ? AssetStatus.IN_USE.name() : AssetStatus.IDLE.name());
    }
    assetChangeLogMapper.insertAssetChangeLog(AssetChangeLog.ofInventory(bo.getAssetId(), operator));
}
```

```java
public void confirmDisposal(AssetDisposalBo bo, String operator) {
    AssetLedger asset = assetLedgerMapper.selectById(bo.getAssetId());
    if (!AssetStatus.PENDING_DISPOSAL.name().equals(asset.getStatus())) {
        throw new ServiceException("只有待处置资产才能确认处置");
    }
    assetDisposalMapper.insertAssetDisposal(convert(bo, operator));
    assetLedgerMapper.updateStatus(bo.getAssetId(), AssetStatus.DISPOSED.name());
}
```

