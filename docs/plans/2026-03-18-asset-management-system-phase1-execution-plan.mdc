public Long createAsset(AssetLedgerBo bo, String operator) {
    if (assetLedgerMapper.selectByAssetCode(bo.getAssetCode()) != null) {
        throw new ServiceException("资产编码已存在");
    }
    AssetLedger entity = convert(bo);
    entity.setStatus(AssetStatus.IN_LEDGER.name());
    entity.setCreateBy(operator);
    assetLedgerMapper.insertAsset(entity);
    assetChangeLogMapper.insertAssetChangeLog(AssetChangeLog.ofCreate(entity.getAssetId(), operator));
    return entity.getAssetId();
}
```

