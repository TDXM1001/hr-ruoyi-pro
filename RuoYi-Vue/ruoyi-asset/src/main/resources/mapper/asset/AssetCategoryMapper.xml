<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.AssetCategoryMapper">

    <resultMap type="com.ruoyi.asset.domain.AssetCategory" id="AssetCategoryResult">
        <result property="id" column="id" />
        <result property="parentId" column="parent_id" />
        <result property="name" column="name" />
        <result property="code" column="code" />
        <result property="level" column="level" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="selectAssetCategoryVo">
        select id, parent_id, name, code, level, create_time from asset_category
    </sql>

    <select id="selectAssetCategoryList" parameterType="com.ruoyi.asset.domain.AssetCategory" resultMap="AssetCategoryResult">
        <include refid="selectAssetCategoryVo"/>
        <where>
            <if test="parentId != null "> and parent_id = #{parentId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="level != null "> and level = #{level}</if>
        </where>
    </select>

    <select id="selectAssetCategoryById" parameterType="Long" resultMap="AssetCategoryResult">
        <include refid="selectAssetCategoryVo"/>
        where id = #{id}
    </select>

    <insert id="insertAssetCategory" parameterType="com.ruoyi.asset.domain.AssetCategory" useGeneratedKeys="true" keyProperty="id">
        insert into asset_category
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null">parent_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="code != null">code,</if>
            <if test="level != null">level,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null">#{parentId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="code != null">#{code},</if>
            <if test="level != null">#{level},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateAssetCategory" parameterType="com.ruoyi.asset.domain.AssetCategory">
        update asset_category
        <trim prefix="SET" suffixOverrides=",">
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="code != null">code = #{code},</if>
            <if test="level != null">level = #{level},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAssetCategoryById" parameterType="Long">
        delete from asset_category where id = #{id}
    </delete>

    <delete id="deleteAssetCategoryByIds" parameterType="String">
        delete from asset_category where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
