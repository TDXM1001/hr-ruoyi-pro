<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.AssetRealEstateOwnershipChangeMapper">
    <resultMap type="com.ruoyi.asset.domain.AssetRealEstateOwnershipChange" id="AssetRealEstateOwnershipChangeResult">
        <id property="ownershipChangeNo" column="ownership_change_no"/>
        <result property="assetId" column="asset_id"/>
        <result property="assetNo" column="asset_no"/>
        <result property="applyUserId" column="apply_user_id"/>
        <result property="applyDeptId" column="apply_dept_id"/>
        <result property="status" column="status"/>
        <result property="oldRightsHolder" column="old_rights_holder"/>
        <result property="targetRightsHolder" column="target_rights_holder"/>
        <result property="oldPropertyCertNo" column="old_property_cert_no"/>
        <result property="targetPropertyCertNo" column="target_property_cert_no"/>
        <result property="oldRegistrationDate" column="old_registration_date"/>
        <result property="targetRegistrationDate" column="target_registration_date"/>
        <result property="reason" column="reason"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOwnershipChangeVo">
        select ownership_change_no, asset_id, asset_no, apply_user_id, apply_dept_id, status,
               old_rights_holder, target_rights_holder, old_property_cert_no, target_property_cert_no,
               old_registration_date, target_registration_date, reason, create_time, update_time, remark
        from asset_real_estate_ownership_change
    </sql>

    <select id="selectOwnershipChangeByNo" parameterType="String" resultMap="AssetRealEstateOwnershipChangeResult">
        <include refid="selectOwnershipChangeVo"/>
        where ownership_change_no = #{ownershipChangeNo}
    </select>

    <select id="selectOwnershipChangeList" parameterType="com.ruoyi.asset.domain.AssetRealEstateOwnershipChange" resultMap="AssetRealEstateOwnershipChangeResult">
        <include refid="selectOwnershipChangeVo"/>
        <where>
            <if test="ownershipChangeNo != null and ownershipChangeNo != ''">and ownership_change_no = #{ownershipChangeNo}</if>
            <if test="assetId != null">and asset_id = #{assetId}</if>
            <if test="assetNo != null and assetNo != ''">and asset_no = #{assetNo}</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertOwnershipChange" parameterType="com.ruoyi.asset.domain.AssetRealEstateOwnershipChange">
        insert into asset_real_estate_ownership_change
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ownershipChangeNo != null">ownership_change_no,</if>
            <if test="assetId != null">asset_id,</if>
            <if test="assetNo != null">asset_no,</if>
            <if test="applyUserId != null">apply_user_id,</if>
            <if test="applyDeptId != null">apply_dept_id,</if>
            <if test="status != null">status,</if>
            <if test="oldRightsHolder != null">old_rights_holder,</if>
            <if test="targetRightsHolder != null">target_rights_holder,</if>
            <if test="oldPropertyCertNo != null">old_property_cert_no,</if>
            <if test="targetPropertyCertNo != null">target_property_cert_no,</if>
            <if test="oldRegistrationDate != null">old_registration_date,</if>
            <if test="targetRegistrationDate != null">target_registration_date,</if>
            <if test="reason != null">reason,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ownershipChangeNo != null">#{ownershipChangeNo},</if>
            <if test="assetId != null">#{assetId},</if>
            <if test="assetNo != null">#{assetNo},</if>
            <if test="applyUserId != null">#{applyUserId},</if>
            <if test="applyDeptId != null">#{applyDeptId},</if>
            <if test="status != null">#{status},</if>
            <if test="oldRightsHolder != null">#{oldRightsHolder},</if>
            <if test="targetRightsHolder != null">#{targetRightsHolder},</if>
            <if test="oldPropertyCertNo != null">#{oldPropertyCertNo},</if>
            <if test="targetPropertyCertNo != null">#{targetPropertyCertNo},</if>
            <if test="oldRegistrationDate != null">#{oldRegistrationDate},</if>
            <if test="targetRegistrationDate != null">#{targetRegistrationDate},</if>
            <if test="reason != null">#{reason},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateOwnershipChange" parameterType="com.ruoyi.asset.domain.AssetRealEstateOwnershipChange">
        update asset_real_estate_ownership_change
        <trim prefix="SET" suffixOverrides=",">
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where ownership_change_no = #{ownershipChangeNo}
    </update>
</mapper>
