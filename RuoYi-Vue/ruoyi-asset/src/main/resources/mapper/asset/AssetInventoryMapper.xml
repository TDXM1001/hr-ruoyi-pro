<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.AssetInventoryMapper">

    <resultMap id="AssetInventoryTaskResult" type="com.ruoyi.asset.domain.AssetInventoryTask">
        <id property="taskId" column="task_id"/>
        <result property="taskNo" column="task_no"/>
        <result property="taskName" column="task_name"/>
        <result property="taskStatus" column="task_status"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeValue" column="scope_value"/>
        <result property="plannedDate" column="planned_date"/>
        <result property="completedDate" column="completed_date"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <resultMap id="AssetInventoryTaskVoResult" type="com.ruoyi.asset.domain.vo.AssetInventoryTaskVo">
        <id property="taskId" column="task_id"/>
        <result property="taskNo" column="task_no"/>
        <result property="taskName" column="task_name"/>
        <result property="taskStatus" column="task_status"/>
        <result property="scopeType" column="scope_type"/>
        <result property="scopeValue" column="scope_value"/>
        <result property="plannedDate" column="planned_date"/>
        <result property="completedDate" column="completed_date"/>
        <result property="scopeAssetCount" column="scope_asset_count"/>
        <result property="submittedCount" column="submitted_count"/>
        <result property="abnormalCount" column="abnormal_count"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <resultMap id="AssetInventoryTaskAssetVoResult" type="com.ruoyi.asset.domain.vo.AssetInventoryTaskAssetVo">
        <result property="taskId" column="task_id"/>
        <id property="assetId" column="asset_id"/>
        <result property="assetCode" column="asset_code"/>
        <result property="assetName" column="asset_name"/>
        <result property="assetStatus" column="asset_status"/>
        <result property="ownerDeptName" column="owner_dept_name"/>
        <result property="useDeptName" column="use_dept_name"/>
        <result property="responsibleUserName" column="responsible_user_name"/>
        <result property="locationName" column="location_name"/>
        <result property="resultRegistered" column="result_registered"/>
        <result property="inventoryResult" column="inventory_result"/>
        <result property="followUpAction" column="follow_up_action"/>
        <result property="processStatus" column="process_status"/>
        <result property="checkedBy" column="checked_by"/>
        <result property="checkedTime" column="checked_time"/>
    </resultMap>

    <resultMap id="AssetInventoryItemResult" type="com.ruoyi.asset.domain.AssetInventoryItem">
        <id property="itemId" column="item_id"/>
        <result property="taskId" column="task_id"/>
        <result property="assetId" column="asset_id"/>
        <result property="inventoryResult" column="inventory_result"/>
        <result property="actualLocationName" column="actual_location_name"/>
        <result property="actualUseDeptId" column="actual_use_dept_id"/>
        <result property="actualResponsibleUserId" column="actual_responsible_user_id"/>
        <result property="followUpAction" column="follow_up_action"/>
        <result property="processStatus" column="process_status"/>
        <result property="processTime" column="process_time"/>
        <result property="followUpBizId" column="follow_up_biz_id"/>
        <result property="checkedBy" column="checked_by"/>
        <result property="checkedTime" column="checked_time"/>
        <result property="resultDesc" column="result_desc"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectTaskColumns">
        select t.task_id, t.task_no, t.task_name, t.task_status, t.scope_type, t.scope_value, t.planned_date, t.completed_date,
               ifnull(task_stats.submitted_count, 0) as submitted_count,
               ifnull(task_stats.abnormal_count, 0) as abnormal_count,
               case
                 when t.scope_value is null or t.scope_value = '' then 0
                 else length(t.scope_value) - length(replace(t.scope_value, ',', '')) + 1
               end as scope_asset_count,
               t.create_by, t.create_time, t.update_by, t.update_time, t.remark
        from ast_asset_inventory_task t
        left join (
            select task_id,
                   count(1) as submitted_count,
                   sum(case when inventory_result in ('LOSS', 'MISSING', 'DAMAGED') then 1 else 0 end) as abnormal_count
            from ast_asset_inventory_item
            group by task_id
        ) task_stats on task_stats.task_id = t.task_id
    </sql>

    <select id="selectAssetInventoryTaskList" parameterType="com.ruoyi.asset.domain.bo.AssetInventoryTaskBo" resultMap="AssetInventoryTaskVoResult">
        <include refid="selectTaskColumns"/>
        <where>
            1 = 1
            <if test="taskId != null">
                and t.task_id = #{taskId}
            </if>
            <if test="taskNo != null and taskNo != ''">
                and t.task_no like concat('%', #{taskNo}, '%')
            </if>
            <if test="taskName != null and taskName != ''">
                and t.task_name like concat('%', #{taskName}, '%')
            </if>
            <if test="taskStatus != null and taskStatus != ''">
                and t.task_status = #{taskStatus}
            </if>
            <if test="scopeType != null and scopeType != ''">
                and t.scope_type = #{scopeType}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(t.planned_date, '%Y%m%d') &gt;= date_format(#{params.beginTime}, '%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(t.planned_date, '%Y%m%d') &lt;= date_format(#{params.endTime}, '%Y%m%d')
            </if>
        </where>
        order by t.planned_date desc, t.task_id desc
    </select>

    <select id="selectAssetInventoryTaskById" parameterType="Long" resultMap="AssetInventoryTaskResult">
        <include refid="selectTaskColumns"/>
        where t.task_id = #{taskId}
    </select>

    <select id="selectTaskAssetList" parameterType="com.ruoyi.asset.domain.bo.AssetInventoryTaskAssetBo" resultMap="AssetInventoryTaskAssetVoResult">
        select t.task_id,
               a.asset_id,
               a.asset_code,
               a.asset_name,
               a.asset_status,
               owner_dept.dept_name as owner_dept_name,
               use_dept.dept_name as use_dept_name,
               ifnull(nullif(u.nick_name, ''), u.user_name) as responsible_user_name,
               a.location_name,
               case when i.item_id is null then 0 else 1 end as result_registered,
               i.inventory_result,
               i.follow_up_action,
               i.process_status,
               i.checked_by,
               i.checked_time
        from ast_asset_inventory_task t
        join ast_asset_ledger a on find_in_set(a.asset_id, t.scope_value) and a.del_flag = '0'
        left join ast_asset_inventory_item i on i.task_id = t.task_id and i.asset_id = a.asset_id
        left join sys_dept owner_dept on a.owner_dept_id = owner_dept.dept_id
        left join sys_dept use_dept on a.use_dept_id = use_dept.dept_id
        left join sys_user u on a.responsible_user_id = u.user_id
        <where>
            t.task_id = #{taskId}
            <if test="assetCode != null and assetCode != ''">
                and a.asset_code like concat('%', #{assetCode}, '%')
            </if>
            <if test="assetName != null and assetName != ''">
                and a.asset_name like concat('%', #{assetName}, '%')
            </if>
            <if test="assetStatus != null and assetStatus != ''">
                and a.asset_status = #{assetStatus}
            </if>
            <if test="resultType != null and resultType == 'PENDING'">
                and i.item_id is null
            </if>
            <if test="resultType != null and resultType == 'REGISTERED'">
                and i.item_id is not null
            </if>
            <if test="resultType != null and resultType == 'ABNORMAL'">
                and i.inventory_result in ('LOSS', 'MISSING', 'DAMAGED')
            </if>
        </where>
        order by case when i.item_id is null then 0 else 1 end asc, a.asset_id asc
    </select>

    <select id="selectAssetInventoryItem" resultMap="AssetInventoryItemResult">
        select item_id, task_id, asset_id, inventory_result, actual_location_name, actual_use_dept_id,
               actual_responsible_user_id, follow_up_action, process_status, process_time, follow_up_biz_id,
               checked_by, checked_time, result_desc, remark
        from ast_asset_inventory_item
        where task_id = #{taskId}
          and asset_id = #{assetId}
        limit 1
    </select>

    <select id="selectMaxTaskNoByPrefix" parameterType="String" resultType="String">
        select max(task_no)
        from ast_asset_inventory_task
        where task_no like concat(#{taskNoPrefix}, '%')
    </select>

    <insert id="insertAssetInventoryTask" parameterType="com.ruoyi.asset.domain.AssetInventoryTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into ast_asset_inventory_task (
            <if test="taskNo != null and taskNo != ''">task_no,</if>
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="taskStatus != null and taskStatus != ''">task_status,</if>
            <if test="scopeType != null and scopeType != ''">scope_type,</if>
            <if test="scopeValue != null and scopeValue != ''">scope_value,</if>
            <if test="plannedDate != null">planned_date,</if>
            <if test="completedDate != null">completed_date,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        ) values (
            <if test="taskNo != null and taskNo != ''">#{taskNo},</if>
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="taskStatus != null and taskStatus != ''">#{taskStatus},</if>
            <if test="scopeType != null and scopeType != ''">#{scopeType},</if>
            <if test="scopeValue != null and scopeValue != ''">#{scopeValue},</if>
            <if test="plannedDate != null">#{plannedDate},</if>
            <if test="completedDate != null">#{completedDate},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <insert id="insertAssetInventoryItem" parameterType="com.ruoyi.asset.domain.AssetInventoryItem" useGeneratedKeys="true" keyProperty="itemId">
        insert into ast_asset_inventory_item (
            <if test="taskId != null">task_id,</if>
            <if test="assetId != null">asset_id,</if>
            <if test="inventoryResult != null and inventoryResult != ''">inventory_result,</if>
            <if test="actualLocationName != null and actualLocationName != ''">actual_location_name,</if>
            <if test="actualUseDeptId != null">actual_use_dept_id,</if>
            <if test="actualResponsibleUserId != null">actual_responsible_user_id,</if>
            <if test="followUpAction != null and followUpAction != ''">follow_up_action,</if>
            <if test="processStatus != null and processStatus != ''">process_status,</if>
            <if test="processTime != null">process_time,</if>
            <if test="followUpBizId != null">follow_up_biz_id,</if>
            <if test="checkedBy != null and checkedBy != ''">checked_by,</if>
            <if test="checkedTime != null">checked_time,</if>
            <if test="resultDesc != null and resultDesc != ''">result_desc,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        ) values (
            <if test="taskId != null">#{taskId},</if>
            <if test="assetId != null">#{assetId},</if>
            <if test="inventoryResult != null and inventoryResult != ''">#{inventoryResult},</if>
            <if test="actualLocationName != null and actualLocationName != ''">#{actualLocationName},</if>
            <if test="actualUseDeptId != null">#{actualUseDeptId},</if>
            <if test="actualResponsibleUserId != null">#{actualResponsibleUserId},</if>
            <if test="followUpAction != null and followUpAction != ''">#{followUpAction},</if>
            <if test="processStatus != null and processStatus != ''">#{processStatus},</if>
            <if test="processTime != null">#{processTime},</if>
            <if test="followUpBizId != null">#{followUpBizId},</if>
            <if test="checkedBy != null and checkedBy != ''">#{checkedBy},</if>
            <if test="checkedTime != null">#{checkedTime},</if>
            <if test="resultDesc != null and resultDesc != ''">#{resultDesc},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <select id="countInventoryItemByTaskId" parameterType="Long" resultType="Long">
        select count(1)
        from ast_asset_inventory_item
        where task_id = #{taskId}
    </select>

    <update id="updateTaskStatus">
        update ast_asset_inventory_task
        set task_status = #{taskStatus},
            completed_date = #{completedDate},
            update_by = #{updateBy},
            update_time = sysdate()
        where task_id = #{taskId}
    </update>

    <select id="countOverdueInventoryTask" resultType="Long">
        select count(1)
        from ast_asset_inventory_task
        where planned_date &lt; curdate()
          and task_status in ('DRAFT', 'IN_PROGRESS')
    </select>
</mapper>
