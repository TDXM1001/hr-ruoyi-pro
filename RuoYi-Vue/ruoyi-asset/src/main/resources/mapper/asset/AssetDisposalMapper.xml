<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.AssetDisposalMapper">
    <resultMap type="com.ruoyi.asset.domain.AssetDisposal" id="AssetDisposalResult">
        <id property="disposalNo" column="disposal_no"/>
        <result property="assetId" column="asset_id"/>
        <result property="assetNo" column="asset_no"/>
        <result property="applyUserId" column="apply_user_id"/>
        <result property="applyDeptId" column="apply_dept_id"/>
        <result property="reason" column="reason"/>
        <result property="disposalType" column="disposal_type"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectAssetDisposalByDisposalNo" parameterType="String" resultMap="AssetDisposalResult">
        select disposal_no, asset_id, asset_no, apply_user_id, apply_dept_id, reason, disposal_type, status, create_time
        from asset_disposal
        where disposal_no = #{disposalNo}
    </select>

    <select id="selectAssetDisposalList" parameterType="com.ruoyi.asset.domain.AssetDisposal" resultMap="AssetDisposalResult">
        select disposal_no, asset_id, asset_no, apply_user_id, apply_dept_id, reason, disposal_type, status, create_time
        from asset_disposal
        <where>
            <if test="disposalNo != null and disposalNo != ''">and disposal_no = #{disposalNo}</if>
            <if test="assetId != null">and asset_id = #{assetId}</if>
            <if test="assetNo != null and assetNo != ''">and asset_no = #{assetNo}</if>
            <if test="disposalType != null and disposalType != ''">and disposal_type = #{disposalType}</if>
            <if test="status != null">and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertAssetDisposal" parameterType="com.ruoyi.asset.domain.AssetDisposal">
        insert into asset_disposal
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="disposalNo != null">disposal_no,</if>
            <if test="assetId != null">asset_id,</if>
            <if test="assetNo != null">asset_no,</if>
            <if test="applyUserId != null">apply_user_id,</if>
            <if test="applyDeptId != null">apply_dept_id,</if>
            <if test="reason != null">reason,</if>
            <if test="disposalType != null and disposalType != ''">disposal_type,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="disposalNo != null">#{disposalNo},</if>
            <if test="assetId != null">#{assetId},</if>
            <if test="assetNo != null">#{assetNo},</if>
            <if test="applyUserId != null">#{applyUserId},</if>
            <if test="applyDeptId != null">#{applyDeptId},</if>
            <if test="reason != null">#{reason},</if>
            <if test="disposalType != null and disposalType != ''">#{disposalType},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateAssetDisposal" parameterType="com.ruoyi.asset.domain.AssetDisposal">
        update asset_disposal
        <set>
            <if test="reason != null">reason = #{reason},</if>
            <if test="disposalType != null and disposalType != ''">disposal_type = #{disposalType},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where disposal_no = #{disposalNo}
    </update>
</mapper>
