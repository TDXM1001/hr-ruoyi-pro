<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.workflow.mapper.WfApprovalTemplateMapper">

    <resultMap id="WfApprovalTemplateResult" type="com.ruoyi.workflow.domain.WfApprovalTemplate">
        <id property="templateId" column="template_id"/>
        <result property="businessType" column="business_type"/>
        <result property="templateName" column="template_name"/>
        <result property="approverId" column="approver_id"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectEnabledTemplateByBusinessType" parameterType="String" resultMap="WfApprovalTemplateResult">
        select template_id,
               business_type,
               template_name,
               approver_id,
               status,
               create_time
        from wf_approval_template
        where business_type = #{businessType}
          and status = '0'
        order by template_id desc
        limit 1
    </select>
</mapper>
