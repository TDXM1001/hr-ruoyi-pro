<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.workflow.mapper.WfApprovalNodeMapper">

    <insert id="insertWfApprovalNode" parameterType="com.ruoyi.workflow.domain.WfApprovalNode"
            useGeneratedKeys="true" keyProperty="nodeId">
        insert into wf_approval_node (
            instance_id,
            approver_id,
            action,
            comment,
            process_time
        ) values (
            #{instanceId},
            #{approverId},
            #{action},
            #{comment},
            #{processTime}
        )
    </insert>
</mapper>
